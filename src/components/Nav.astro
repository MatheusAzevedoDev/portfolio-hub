---
import { SITE_CONFIG } from '../config';

interface Props {
  activePage?: 'blog';
  transparent?: boolean;
}

const { activePage, transparent = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<nav id="main-nav" class:list={[{ 'is-transparent': transparent }]}>
  <div class="nav-inner">
    <a href={`${base}/`} class="nav-logo">
      <svg width="26" height="22" viewBox="0 0 40 32" fill="none">
        <line x1="4" y1="28" x2="4" y2="8" stroke="var(--fg-1)" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="4" y1="8" x2="20" y2="22" stroke="var(--fg-1)" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="20" y1="4" x2="4" y2="8" stroke="var(--accent)" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="20" y1="4" x2="36" y2="8" stroke="var(--accent)" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="20" y1="22" x2="36" y2="8" stroke="var(--fg-1)" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="36" y1="8" x2="36" y2="28" stroke="var(--fg-1)" stroke-width="2.5" stroke-linecap="round"/>
      </svg>
      <div>
        <div class="logo-name">matheus</div>
        <div class="logo-sub">azevedo</div>
      </div>
    </a>
    <div class="nav-links">
      <a href={`${base}/#projects`} class="nav-link">Projetos</a>
      <a href={`${base}/#about`} class="nav-link">Sobre</a>
      <a href={`${base}/#experience`} class="nav-link">Experiência</a>
      <a href={`${base}/blog`} class:list={['nav-link', { 'nav-link-active': activePage === 'blog' }]}>Blog</a>

      <button class="theme-toggle" id="theme-toggle" aria-label="Alternar tema" title="Alternar tema">
        <!-- Sun: visible in dark mode, click to go light -->
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <!-- Moon: visible in light mode, click to go dark -->
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <a href={SITE_CONFIG.linkedinUrl} target="_blank" rel="noopener" class="nav-cta">
        <svg viewBox="0 0 24 24" fill="currentColor" style="width:13px;height:13px;"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        <span class="cta-label">LinkedIn</span>
      </a>
      <a href={`https://github.com/${SITE_CONFIG.githubUser}`} target="_blank" rel="noopener" class="nav-cta">
        <svg viewBox="0 0 24 24" fill="currentColor" style="width:13px;height:13px;"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        <span class="cta-label">GitHub</span>
      </a>
    </div>
  </div>
</nav>

<style>
  #main-nav {
    position: sticky; top: 0; z-index: 100;
    padding: 0 32px;
    background: var(--nav-bg);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    transition: background 300ms, border-color 300ms;
  }
  #main-nav.is-transparent {
    background: transparent;
    backdrop-filter: none;
    border-bottom-color: transparent;
  }
  #main-nav.scrolled {
    background: var(--nav-bg-solid);
    backdrop-filter: blur(16px);
    border-bottom-color: var(--border);
  }
  .nav-inner {
    max-width: 1100px; margin: 0 auto;
    height: 60px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-logo {
    display: flex; align-items: center; gap: 10px; text-decoration: none;
  }
  .logo-name {
    font-family: var(--font-display); font-weight: 800; font-size: 15px;
    color: var(--fg-1); letter-spacing: -0.02em; line-height: 1.1;
  }
  .logo-sub {
    font-size: 9px; color: var(--accent); letter-spacing: 0.1em;
    font-weight: 600; text-transform: uppercase;
  }
  .nav-links {
    display: flex; align-items: center; gap: 4px;
  }
  .nav-link {
    font-size: 13px; font-weight: 500; color: var(--fg-2);
    padding: 6px 12px; border-radius: 6px;
    transition: all 150ms; text-decoration: none;
  }
  .nav-link:hover { color: var(--fg-1); background: var(--bg-elevated); }
  .nav-link-active { color: var(--fg-1) !important; background: var(--bg-elevated); }
  .nav-cta {
    display: flex; align-items: center; gap: 6px;
    background: var(--accent); color: #fff;
    padding: 7px 14px; border-radius: 7px;
    font-size: 13px; font-weight: 600;
    margin-left: 8px;
    box-shadow: 0 0 20px oklch(65% 0.28 268 / 0.3);
    transition: all 150ms; text-decoration: none;
  }
  .nav-cta:hover { background: var(--accent-bright); }

  /* Theme toggle */
  .theme-toggle {
    display: flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; border-radius: 7px;
    background: none; border: 1px solid transparent;
    color: var(--fg-3); cursor: pointer;
    transition: all 150ms;
    margin-left: 4px;
  }
  .theme-toggle:hover {
    color: var(--fg-1);
    background: var(--bg-elevated);
    border-color: var(--border);
  }
  /* Dark mode: show sun, hide moon */
  .icon-sun  { display: block; }
  .icon-moon { display: none; }
  /* Light mode: show moon, hide sun */
  :global([data-theme="light"]) .icon-sun  { display: none; }
  :global([data-theme="light"]) .icon-moon { display: block; }

  @media (max-width: 768px) {
    #main-nav { padding: 0 20px; }
  }
  @media (max-width: 640px) {
    #main-nav { padding: 0 16px; }
    .nav-link { display: none; }
  }
  @media (max-width: 520px) {
    .cta-label { display: none; }
    .nav-cta { padding: 7px 10px; gap: 0; margin-left: 4px; }
    .theme-toggle { margin-left: 0; }
  }
</style>

<script>
  const nav = document.getElementById('main-nav');
  if (nav?.classList.contains('is-transparent')) {
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 20);
    }, { passive: true });
  }

  const btn = document.getElementById('theme-toggle');
  const html = document.documentElement;

  function applyTheme(theme: string) {
    if (theme === 'light') {
      html.setAttribute('data-theme', 'light');
    } else {
      html.removeAttribute('data-theme');
    }
    localStorage.setItem('portfolio-theme', theme);
  }

  btn?.addEventListener('click', () => {
    const current = html.getAttribute('data-theme');
    applyTheme(current === 'light' ? 'dark' : 'light');
  });
</script>
